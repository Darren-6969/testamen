# .env.local - Environment Variables
# API Configuration (disabled by default)
NEXT_PUBLIC_API_URL=http://192.168.2.100:3001/api
NEXT_PUBLIC_API_ENABLED=TRUE
NEXT_PUBLIC_ENV=local

# App Configuration
NEXT_PUBLIC_APP_NAME=Reach 10 App
NEXT_PUBLIC_APP_VERSION=0.1.0

# Development flags
NEXT_PUBLIC_DEV_MODE=false
NEXT_PUBLIC_SHOW_MOCK_DATA=true

# Authentication (for when API is ready)
NEXT_PUBLIC_AUTH_ENABLED=false
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3003

